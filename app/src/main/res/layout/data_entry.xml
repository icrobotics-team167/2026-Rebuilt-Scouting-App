                            android:layout_height="match_parent"
                            android:orientation="horizontal"
                            android:weightSum="64">

                            <TextView
                                android:id="@+id/commentsHeader2"
                                style="@style/AutoResize25"
                                android:layout_width="0dp"
                                android:layout_height="match_parent"
                                android:layout_weight="15"
                                android:gravity="center"
                                android:text="Auto Notes:" />

                            <EditText
                                android:id="@+id/autoComments"
                                android:layout_width="0dp"
                                android:layout_height="wrap_content"
                                android:layout_gravity="center"
                                android:layout_weight="49"
                                android:ems="10"
                                android:hint="@string/data_entry_auto_notes"
                                android:inputType="textMultiLine" />
                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:id="@+id/divider11"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="2"
                        android:foreground="?attr/dividerColor" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="14"
                        android:orientation="horizontal">

                        <LinearLayout
                            android:layout_width="match_parent"
                            android:layout_height="match_parent"
                            android:orientation="vertical"
                            android:weightSum="64">

                            <TextView
                                android:id="@+id/textView7"
                                style="@style/AutoResize30"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="60"
                                android:gravity="center"
                                android:text="@string/data_entry_end_of_game_header" />

                            <View
                                android:id="@+id/divider15"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="4"
                                android:foreground="?attr/dividerColor" />

                        </LinearLayout>

                    </LinearLayout>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="34"
                        android:orientation="horizontal"
                        android:weightSum="6">

                        <TextView
                            android:id="@+id/commentsHeader"
                            style="@style/AutoResize25"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1"
                            android:gravity="center"
                            android:text="@string/data_entry_notes_header" />

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="3.5"
                            android:gravity="center"
                            android:orientation="vertical">

                            <EditText
                                android:id="@+id/comments"
                                style="@style/AutoResize20"
                                android:layout_width="match_parent"
                                android:layout_height="wrap_content"
                                android:ems="10"
                                android:gravity="bottom"
                                android:hint="@string/data_entry_general_notes"
                                android:inputType="textMultiLine"
                                android:text="" />
                        </LinearLayout>

                        <LinearLayout
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1.5"
                            android:gravity="center"
                            android:orientation="vertical"
                            android:weightSum="3">

                            <Button
                                android:id="@+id/saveExitButton"
                                style="@style/AutoResize20"
                                android:layout_width="match_parent"
                                android:layout_height="0dp"
                                android:layout_weight="1"
                                android:backgroundTint="?attr/colorPrimary"
                                android:text="@string/data_entry_save_exit"
                                android:textColor="?attr/buttonTextPrimary" />
                        </LinearLayout>

                    </LinearLayout>

                    <View
                        android:id="@+id/divider17"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="2"
                        android:foreground="?attr/dividerColor" />

                </LinearLayout>

                <View
                    android:id="@+id/divider9"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1"
                    android:foreground="?attr/dividerColor" />

            </LinearLayout>
        </FrameLayout>

    </LinearLayout>
</androidx.constraintlayout.widget.ConstraintLayout>