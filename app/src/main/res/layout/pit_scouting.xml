<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:weightSum="64"
        android:background="@color/background"
        android:orientation="horizontal">

        <View
            android:id="@+id/divider31"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?android:attr/listDivider" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="62"
            android:orientation="vertical"
            android:weightSum="68">

            <View
                android:id="@+id/divider33"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1.75"
                android:background="?android:attr/listDivider" />

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="8.25"
                android:orientation="horizontal"
                android:weightSum="48">

                <TextView
                    android:id="@+id/teamNumberHeader"
                    style="@style/AutoResize25"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="7.5"
                    android:gravity="center_vertical"
                    android:paddingStart="10dp"
                    android:text="Team Number:" />

                <FrameLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="5.6">

                    <Spinner
                        android:id="@+id/teamNumberSpinner"
                        android:visibility="visible"
                        style="@style/AutoResize25"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent" />

                    <EditText
                        android:id="@+id/teamNumberText"
                        android:visibility="gone"
                        android:layout_width="match_parent"
                        android:layout_height="match_parent"
                        android:ems="10"
                        android:inputType="numberSigned"
                        android:hint="Enter Team" />
                </FrameLayout>

                <TextView
                    android:id="@+id/scouterHeader"
                    style="@style/AutoResize25"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="4"
                    android:paddingStart="10dp"
                    android:gravity="center_vertical"
                    android:text="Name:" />

                <EditText
                    android:id="@+id/scouter"
                    style="@style/AutoResize20"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="5"
                    android:ems="10"
                    android:inputType="text"
                    android:hint="Your name"
                    android:text="" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="6"
                    android:weightSum="5"
                    android:orientation="vertical">

                    <Space
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="0.5" />

                    <TextView
                        android:id="@+id/textView2"
                        style="@style/AutoResize25"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="2"
                        android:gravity="center"
                        android:text="Day 1 / Day 2" />

                    <Switch
                        android:id="@+id/daySwitch"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_weight="2"
                        android:layout_gravity="center"
                        android:scaleX="1.25"
                        android:scaleY="1.25"
                        android:text="" />
                </LinearLayout>

                <Space
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/editButton"
                    style="@style/AutoResize20"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="5"
                    android:layout_gravity="center"
                    android:backgroundTint="@color/secondaryForeground"
                    android:textColor="@color/black"
                    android:text="Edit Old Data" />

                <Spinner
                    android:id="@+id/editTeamSpinner"
                    style="@style/AutoResize25"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="8" />

                <Space
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_weight="1" />

                <Button
                    android:id="@+id/exportButton"
                    style="@style/AutoResize20"
                    android:layout_width="0dp"
                    android:layout_height="match_parent"
                    android:layout_gravity="center"
                    android:layout_weight="5"
                    android:backgroundTint="@color/secondaryForeground"
                    android:text="Export All Data"
                    android:textColor="@color/black" />

            </LinearLayout>

            <View
                android:id="@+id/divider25"
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="1"
                android:background="?android:attr/listDivider" />

            <FrameLayout
                android:layout_width="match_parent"
                android:layout_height="0dp"
                android:layout_weight="57">

                <LinearLayout
                    android:id="@+id/day2"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="gone"
                    android:weightSum="68">

                    <TextView
                        android:id="@+id/autoNotesHeader"
                        style="@style/AutoResize25"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="4"
                        android:paddingStart="5dp"
                        android:text="Auto Notes:" />

                    <EditText
                        android:id="@+id/day2AutoNotes"
                        style="@style/AutoResize20"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="15.5"
                        android:ems="10"
                        android:hint="Auto Notes"
                        android:inputType="text" />

                    <TextView
                        android:id="@+id/teleopNotesHeader"
                        style="@style/AutoResize25"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="4"
                        android:paddingStart="5dp"
                        android:text="Teleop Notes:" />

                    <EditText
                        android:id="@+id/teleopNotes"
                        style="@style/AutoResize20"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="16"
                        android:ems="10"
                        android:hint="Teleop Notes"
                        android:inputType="text" />

                    <TextView
                        android:id="@+id/textView14"
                        style="@style/AutoResize25"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="4"
                        android:paddingStart="5dp"
                        android:text="General Notes:" />

                    <EditText
                        android:id="@+id/day2Comments"
                        style="@style/AutoResize20"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="16"
                        android:ems="10"
                        android:hint="General Notes"
                        android:inputType="text" />

                    <Button
                        android:id="@+id/day2SaveExitButton"
                        style="@style/AutoResize25"
                        android:layout_width="wrap_content"
                        android:layout_height="0dp"
                        android:layout_gravity="center"
                        android:layout_weight="7"
                        android:text="Save and Exit"
                        android:textColor="@color/white" />

                    <View
                        android:id="@+id/divider20"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.75"
                        android:background="?android:attr/listDivider" />
                </LinearLayout>

                <LinearLayout
                    android:id="@+id/day1"
                    android:layout_width="match_parent"
                    android:layout_height="match_parent"
                    android:orientation="vertical"
                    android:visibility="visible">

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="6"
                        android:orientation="horizontal"
                        android:weightSum="48">

                        <TextView
                            android:id="@+id/robotHeader"
                            style="@style/AutoResize25"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="6"
                            android:gravity="center|start"
                            android:paddingStart="10dp"
                            android:text="Robot:" />

                        <CheckBox
                            android:id="@+id/award"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="5"
                            android:text="Award" />

                        <CheckBox
                            android:id="@+id/bump"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="5"
                            android:text="Bump" />

                        <CheckBox
                            android:id="@+id/trench"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="5"
                            android:text="Trench" />

                        <TextView
                            android:id="@+id/botHeightHeader"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="5"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:text="Bot Height:" />

                        <EditText
                            android:id="@+id/botHeight"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="3"
                            android:ems="10"
                            android:gravity="center"
                            android:hint="H"
                            android:inputType="numberDecimal|numberSigned"
                            android:paddingTop="10dp"
                            android:text="" />

                        <Spinner
                            android:id="@+id/heightUnitsSpinner"
                            style="@style/AutoResize25"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="5.5" />

                        <TextView
                            android:id="@+id/botWeightHeader"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="5"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:text="Bot Weight:" />

                        <EditText
                            android:id="@+id/botWeight"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="3"
                            android:ems="10"
                            android:gravity="center"
                            android:hint="W"
                            android:inputType="numberDecimal|numberSigned"
                            android:paddingTop="10dp"
                            android:text="" />

                        <Spinner
                            android:id="@+id/weightUnitsSpinner"
                            style="@style/AutoResize25"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="5.5" />

                    </LinearLayout>

                    <View
                        android:id="@+id/divider12"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="?android:attr/listDivider" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="6"
                        android:orientation="horizontal"
                        android:weightSum="48">

                        <TextView
                            android:id="@+id/drivebaseHeader"
                            style="@style/AutoResize25"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="6"
                            android:gravity="center|start"
                            android:paddingStart="10dp"
                            android:text="Drivebase:" />

                        <CheckBox
                            android:id="@+id/swerve"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="7"
                            android:text="Swerve" />

                        <TextView
                            android:id="@+id/motorTypeHeader"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="5"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:text="Motor Type:" />

                        <Spinner
                            android:id="@+id/motorTypeSpinner"
                            style="@style/AutoResize25"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="9" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/swerveModuleHeader"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="6"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:text="Swerve Module:" />

                        <EditText
                            android:id="@+id/swerveModule"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="4"
                            android:ems="10"
                            android:gravity="center"
                            android:hint="e.g. Mk5n"
                            android:inputType="text"
                            android:paddingTop="10dp"
                            android:text="" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1" />

                        <TextView
                            android:id="@+id/gearRatioHeader"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="5"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:text="Gear Ratio:" />

                        <EditText
                            android:id="@+id/gearRatio"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="3"
                            android:ems="10"
                            android:gravity="center"
                            android:hint="e.g. L2"
                            android:inputType="text"
                            android:paddingTop="10dp"
                            android:text="" />

                    </LinearLayout>

                    <View
                        android:id="@+id/divider26"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="?android:attr/listDivider" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="6"
                        android:orientation="horizontal"
                        android:weightSum="48">

                        <TextView
                            android:id="@+id/intakeHeader"
                            style="@style/AutoResize25"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="6"
                            android:gravity="center|start"
                            android:paddingStart="10dp"
                            android:text="Intake:" />

                        <CheckBox
                            android:id="@+id/overBumperIntake"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="7"
                            android:text="Over Bumper" />

                        <CheckBox
                            android:id="@+id/throughBumperIntake"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="8"
                            android:text="Through Bumper" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="7" />

                        <TextView
                            android:id="@+id/textView4"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="8"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:text="Intake Width:" />

                        <EditText
                            android:id="@+id/intakeWidth"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="3"
                            android:ems="10"
                            android:gravity="center"
                            android:hint="W"
                            android:inputType="numberDecimal|numberSigned"
                            android:paddingTop="10dp"
                            android:text="" />

                        <Spinner
                            android:id="@+id/intakeWidthSpinner"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="7" />

                    </LinearLayout>

                    <View
                        android:id="@+id/divider44"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="?android:attr/listDivider" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="6"
                        android:orientation="horizontal"
                        android:weightSum="48">

                        <TextView
                            android:id="@+id/hopperHeader"
                            style="@style/AutoResize25"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="6"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:text="Hopper:" />

                        <CheckBox
                            android:id="@+id/openHopper"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="7"
                            android:text="Open" />

                        <CheckBox
                            android:id="@+id/extendableHopper"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="8"
                            android:text="Extendable" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="7" />

                        <TextView
                            android:id="@+id/textView5"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="8"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:text="Hopper Capacity:" />

                        <EditText
                            android:id="@+id/hopperCapacity"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="3"
                            android:ems="10"
                            android:gravity="center"
                            android:hint="0"
                            android:inputType="numberDecimal|numberSigned"
                            android:paddingTop="10dp"
                            android:text="" />

                    </LinearLayout>

                    <View
                        android:id="@+id/divider27"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="?android:attr/listDivider" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="6"
                        android:orientation="horizontal"
                        android:weightSum="48">

                        <TextView
                            android:id="@+id/turretHeader"
                            style="@style/AutoResize25"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="6"
                            android:gravity="center|start"
                            android:paddingStart="10dp"
                            android:text="Shooter:" />

                        <CheckBox
                            android:id="@+id/tiltTurret"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="7"
                            android:text="Tilt" />

                        <CheckBox
                            android:id="@+id/turnTurret"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="8"
                            android:text="Turn" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="7" />

                        <TextView
                            android:id="@+id/numberOfShootersHeader"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="8"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:text="Number of Shooters:" />

                        <Space
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="0.5" />

                        <EditText
                            android:id="@+id/numberOfShooters"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="2"
                            android:ems="10"
                            android:gravity="center"
                            android:hint="0"
                            android:inputType="numberSigned"
                            android:text="" />

                    </LinearLayout>

                    <View
                        android:id="@+id/divider35"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="?android:attr/listDivider" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="7"
                        android:orientation="horizontal"
                        android:weightSum="48">

                        <TextView
                            android:id="@+id/autoHeader"
                            style="@style/AutoResize25"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="6"
                            android:gravity="center|start"
                            android:paddingStart="10dp"
                            android:text="Auto:" />

                        <CheckBox
                            android:id="@+id/autoCanClimb"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="7"
                            android:text="Can Climb" />

                        <TextView
                            android:id="@+id/numberWorkingAutosHeader"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="7"
                            android:gravity="center_vertical"
                            android:paddingStart="10dp"
                            android:text="Working Autos:" />

                        <EditText
                            android:id="@+id/numberOfAutos"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="2"
                            android:ems="10"
                            android:gravity="center"
                            android:hint="0"
                            android:inputType="numberSigned"
                            android:text="" />

                        <TextView
                            android:id="@+id/autoNotesHeadaer"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="6"
                            android:gravity="center"
                            android:paddingStart="10dp"
                            android:text="Auto Notes:" />

                        <EditText
                            android:id="@+id/autoNotes"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="20"
                            android:ems="10"
                            android:hint="Auto Notes"
                            android:inputType="textMultiLine" />
                    </LinearLayout>

                    <View
                        android:id="@+id/divider28"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="?android:attr/listDivider" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="6"
                        android:orientation="horizontal"
                        android:weightSum="48">

                        <TextView
                            android:id="@+id/cornOnCobHeader"
                            style="@style/AutoResize25"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="6"
                            android:gravity="center|start"
                            android:paddingStart="10dp"
                            android:text="Corn Toppings:" />

                        <CheckBox
                            android:id="@+id/yesCornOnCob"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="7"
                            android:text="Salt" />

                        <CheckBox
                            android:id="@+id/definitelyCornOnCob"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="8"
                            android:text="Pepper" />

                        <CheckBox
                            android:id="@+id/absolutelyCornOnCob"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="7"
                            android:text="Butter" />

                        <CheckBox
                            android:id="@+id/checkBox6"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1.5"
                            android:text="" />

                        <EditText
                            android:id="@+id/editTextText"
                            style="@style/AutoResize20"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="18.5"
                            android:ems="10"
                            android:hint="Other"
                            android:inputType="text"
                            android:paddingTop="5dp" />
                    </LinearLayout>

                    <View
                        android:id="@+id/divider29"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1"
                        android:background="?android:attr/listDivider" />

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="7"
                        android:orientation="horizontal"
                        android:weightSum="12">

                        <TextView
                            android:id="@+id/commentsHeader"
                            style="@style/AutoResize30"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="1.5"
                            android:gravity="center"
                            android:text="Notes:" />

                        <EditText
                            android:id="@+id/comments"
                            style="@style/AutoResize20"
                            android:layout_width="wrap_content"
                            android:layout_height="wrap_content"
                            android:layout_weight="8.5"
                            android:ems="10"
                            android:hint="Notes go here..."
                            android:inputType="textMultiLine" />

                        <Button
                            android:id="@+id/saveExitButton"
                            style="@style/AutoResize25"
                            android:layout_width="0dp"
                            android:layout_height="match_parent"
                            android:layout_weight="2"
                            android:backgroundTint="@color/primaryForeground"
                            android:text="Save and Exit"
                            android:textColor="@color/white" />
                    </LinearLayout>

                    <View
                        android:id="@+id/divider34"
                        android:layout_width="match_parent"
                        android:layout_height="0dp"
                        android:layout_weight="1.25"
                        android:background="?android:attr/listDivider" />
                </LinearLayout>
            </FrameLayout>

        </LinearLayout>

        <View
            android:id="@+id/divider32"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"
            android:background="?android:attr/listDivider" />
    </LinearLayout>

</androidx.constraintlayout.widget.ConstraintLayout>